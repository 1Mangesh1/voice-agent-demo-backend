# --- Tavus CVI (STT + LLM + TTS + talking avatar) ---
TAVUS_API_KEY=
# Stock replica ID. Suggested: r90bbd427f71 (Anna, Phoenix-4, Pro tier).
TAVUS_REPLICA_ID=
# Optional: pre-created persona. Blank → server creates "mira-clinic" on first /tavus/start.
TAVUS_PERSONA_ID=
# Public URL Tavus posts webhooks to. In prod this is your Render service URL.
PUBLIC_BASE_URL=http://localhost:8000

# --- Gemini (post-call summary only) ---
GOOGLE_API_KEY=

# --- Supabase Postgres ---
# Settings → Database → Connection String → URI. Use the SESSION POOLER on port 5432
# (aws-1-<region>.pooler.supabase.com) — direct host is IPv6-only and Render free tier
# can't reach it. URL-encode the password if it contains @ : / etc.
# Blank → falls back to local SQLite at app.db.
DATABASE_URL=

# --- Cost display in /summary card ---
TAVUS_RATE_USD_PER_MIN=0.15
USD_TO_INR=83

PORT=8000
