GOOGLE_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
# Cartesia voice ID — MUST be a UUID (e.g. 694f9389-aac1-45b6-b726-9d9369183238).
# NOT the model name like "sonic-english". Find voices at https://play.cartesia.ai/voices.
# Leave blank to use the built-in default ("Sonia").
CARTESIA_VOICE_ID=
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Supabase Postgres connection string (Settings → Database → Connection String → URI).
# Use the *Session pooler* on port 6543 — works on free Render dynos.
# Example shape (replace with your own; password URL-encoded if it has @ : / etc):
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Leave unset to fall back to local SQLite.
DATABASE_URL=

# Supabase project URL + publishable (anon) key — only needed if/when the
# frontend uses the JS client for Realtime, RLS, or auth. Backend uses
# DATABASE_URL above for direct Postgres access.
SUPABASE_URL=
SUPABASE_KEY=

PORT=8000
